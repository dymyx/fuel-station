{
	"version": 2,
	"buildCommand": "npm run build",
	"outputDirectory": "frontend/dist",
	"functions": {
		"api/[...all].ts": {
			"maxDuration": 30
		}
	},
	"routes": [
		{
			"src": "/api/(.*)",
			"dest": "/api/[...all].ts"
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/index.html"
		}
	]
}
